{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext"
    ],
    "paths": {
			"@/*": ["./src/*"],
      "@contracts/*": ["../../packages/contracts/src/*"],
      "@database/*": ["../../packages/database/src/*"],
		},
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
}